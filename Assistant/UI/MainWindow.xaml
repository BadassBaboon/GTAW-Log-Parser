<Controls:MetroWindow x:Name="Main" x:Class="Assistant.UI.MainWindow"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Assistant.UI"
                      mc:Ignorable="d"
                      ResizeMode="CanMinimize"
                      WindowStartupLocation="CenterScreen"
                      Closing="Main_Closing"
                      GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
                      Title="GTA World Chat Log Assistant" Height="335" Width="640" IsMaxRestoreButtonEnabled="False" IsMinButtonEnabled="True" TitleCharacterCasing="Normal" ShowIconOnTitleBar="False" Icon="../Resources/AppIcon.ico">

    <Controls:MetroWindow.RightWindowCommands>
        <Controls:WindowCommands>
            <Button x:Name="OpenProgramSettings"
                    Click="OpenProgramSettings_Click"
                    Content="{iconPacks:Material Cog, Width=18, Height=18}"
                    ToolTip="Settings" />

            <Button x:Name="OpenGithubProject"
                    Visibility="Collapsed"
                    Click="OpenGithubProject_Click"
                    Content="{iconPacks:Material Github, Width=20, Height=20}"
                    ToolTip="Open the project page on GitHub" />

            <Button x:Name="OpenGithubReleases"
                    Visibility="Collapsed"
                    Click="OpenGithubReleases_Click"
                    Content="{iconPacks:Material Download, Width=16, Height=16}"
                    ToolTip="Open the releases page on GitHub" />

            <Button x:Name="OpenUCP"
                    Visibility="Collapsed"
                    Click="OpenUCP_Click"
                    Content="{iconPacks:Material CardBulletedOutline, Width=20, Height=20}"
                    ToolTip="Open the GTA World UCP" />

            <Button x:Name="OpenFacebrowser"
                    Visibility="Collapsed"
                    Click="OpenFacebrowser_Click"
                    Content="{iconPacks:Material Facebook, Width=16, Height=16}"
                    ToolTip="Open Facebrowser" />

            <Button x:Name="OpenForums"
                    Visibility="Collapsed"
                    Click="OpenForums_Click"
                    Content="{iconPacks:Material Web, Width=18, Height=18}"
                    ToolTip="Open the GTA World forums" />
        </Controls:WindowCommands>
    </Controls:MetroWindow.RightWindowCommands>

    <DockPanel>
        <Menu x:Name="MenuStrip" DockPanel.Dock="Top">
            <MenuItem x:Name="CheckForUpdatesToolStripMenuItem" Header="Check For Updates" Click="CheckForUpdatesToolStripMenuItem_Click"/>
            <MenuItem x:Name="BackupSettingsToolStripMenuItem" Header="Automatic Backup Settings" Click="BackupSettingsToolStripMenuItem_Click"/>
            <MenuItem x:Name="FilterChatLogToolStripMenuItem" Header="Filter Chat Log" Click="FilterChatLogToolStripMenuItem_Click"/>
            <MenuItem x:Name="LiveTailToolStripMenuItem" Header="Live Tail" Click="LiveTailToolStripMenuItem_Click"/>
            <MenuItem x:Name="LanguageToolStripMenuItem" Header="Change Server" Visibility="Collapsed"/>
            <MenuItem x:Name="AboutToolStripMenuItem" Header="About" Click="AboutToolStripMenuItem_Click"/>
            <MenuItem x:Name="ExitToolStripMenuItem" Header="Exit" Visibility="Hidden" Click="ExitToolStripMenuItem_Click"/>
        </Menu>

        <Grid>
            <!-- Log Parser Tab Content -->
            <Grid x:Name="LogParserGrid" Visibility="Visible">
                <Image x:Name="Logo" HorizontalAlignment="Left" Height="140" VerticalAlignment="Top" Width="288" Source="../Resources/Logo.png" Margin="10,0,0,0" Stretch="Fill"/>
                <CheckBox x:Name="CheckForUpdatesOnStartup" Checked="CheckForUpdatesOnStartup_CheckedChanged" Unchecked="CheckForUpdatesOnStartup_CheckedChanged" Content="Check for updates automatically" HorizontalAlignment="Left" Margin="10,145,0,0" VerticalAlignment="Top" Width="288"/>
                <CheckBox x:Name="RemoveTimestamps" Checked="RemoveTimestamps_CheckedChanged" Unchecked="RemoveTimestamps_CheckedChanged" Content="Remove timestamps" HorizontalAlignment="Left" Margin="10,168,0,0" VerticalAlignment="Top" Width="288"/>
                <CheckBox x:Name="BindTilde" Checked="BindTilde_CheckedChanged" Unchecked="BindTilde_CheckedChanged" Content="Bind ~ to T (Like SA:MP)" HorizontalAlignment="Left" Margin="10,191,0,0" VerticalAlignment="Top" Width="288"/>
                <Controls:ProgressRing x:Name="UpdateCheckProgress"
                                       Width="16"
                                       Height="16"
                                       Foreground="Black"
                                       IsActive="False"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Visibility="Collapsed" Margin="210,145,0,0"/>

                <Label x:Name="PathLabel" Content="RAGEMP Directory:" HorizontalContentAlignment="Left" HorizontalAlignment="Left" Margin="298,0,0,0" VerticalAlignment="Top"/>
                <TextBlock x:Name="Version" TextWrapping="NoWrap" Text="v1.0.0" TextAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Width="75" Margin="549,5,0,0" Height="26"/>
                <TextBox x:Name="DirectoryPath" MouseLeftButtonUp="DirectoryPath_MouseLeftButtonUp" TextChanged="DirectoryPath_TextChanged" HorizontalAlignment="Left" Height="23" Margin="303,23,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="241" IsReadOnly="True" VerticalScrollBarVisibility="Disabled"/>
                <Button x:Name="Browse" Click="Browse_Click" Content="Browse" HorizontalAlignment="Left" Margin="549,23,0,0" VerticalAlignment="Top" Width="75"/>
                <TextBox x:Name="Parsed" TextChanged="Parsed_TextChanged" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible" HorizontalAlignment="Left" Height="145" Margin="303,54,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="321" AcceptsReturn="True"/>
                <Label x:Name="StatusLabel" Content="Automatic Backup: OFF" HorizontalContentAlignment="Left" HorizontalAlignment="Left" Margin="298,208,0,0" VerticalAlignment="Top" Width="160"/>
                <TextBlock TextWrapping="NoWrap" x:Name="Counter" Text="0 characters and 0 lines" TextAlignment="Right" HorizontalAlignment="Left" Margin="463,213,0,0" VerticalAlignment="Top" Width="161" Height="26"/>
                
                <Button x:Name="Parse" Click="Parse_Click" Content="Parse" HorizontalAlignment="Left" Margin="303,238,0,0" VerticalAlignment="Top" Width="75"/>
                <Button x:Name="SaveParsed" Click="SaveParsed_Click" Content="Save As" HorizontalAlignment="Left" Margin="383,238,0,0" VerticalAlignment="Top" Width="75"/>
                <Button x:Name="CopyParsedToClipboard" Click="CopyParsedToClipboard_Click" Content="Copy To Clipboard" HorizontalAlignment="Left" Margin="463,238,0,0" VerticalAlignment="Top" Width="161"/>
            </Grid>
            
            <!-- AI Assistant Tab Content -->
            <Grid x:Name="AiAssistantGrid" Visibility="Collapsed">
                <!-- Left Column: Settings -->
                <Label Content="AI Mode:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="100"/>
                <ComboBox x:Name="AiMode" SelectionChanged="AiMode_SelectionChanged" HorizontalAlignment="Left" Margin="10,33,0,0" VerticalAlignment="Top" Width="260">
                    <ComboBoxItem Content="Change Accent"/>
                    <ComboBoxItem Content="Translate Language"/>
                    <ComboBoxItem Content="Auto-Correct"/>
                </ComboBox>

                <Label x:Name="AiTargetLabel" Content="Target Accent (e.g. Texan Accent, Donald Trump):" HorizontalAlignment="Left" Margin="10,65,0,0" VerticalAlignment="Top" Width="280"/>
                <TextBox x:Name="AiTargetInput" TextChanged="AiTargetInput_TextChanged" HorizontalAlignment="Left" Margin="10,88,0,0" VerticalAlignment="Top" Width="260" Height="25" VerticalContentAlignment="Center"/>

                <Label Content="Output Length Constraint:" HorizontalAlignment="Left" Margin="10,120,0,0" VerticalAlignment="Top" Width="180"/>
                <ComboBox x:Name="AiLength" SelectionChanged="AiLength_SelectionChanged" HorizontalAlignment="Left" Margin="10,143,0,0" VerticalAlignment="Top" Width="260">
                    <ComboBoxItem Content="No Constraint"/>
                    <ComboBoxItem Content="Similar Length"/>
                    <ComboBoxItem Content="Concise"/>
                </ComboBox>

                <Label Content="AI Model:" HorizontalAlignment="Left" Margin="10,175,0,0" VerticalAlignment="Top" Width="150"/>
                <ComboBox x:Name="AiModel" IsEditable="True" SelectionChanged="AiModel_SelectionChanged" TextBoxBase.TextChanged="AiModel_TextChanged" HorizontalAlignment="Left" Margin="10,198,0,0" VerticalAlignment="Top" Width="235">
                    <ComboBoxItem Content="llama-3.1-8b-instant"/>
                    <ComboBoxItem Content="llama-3.3-70b-versatile"/>
                    <ComboBoxItem Content="openai/gpt-oss-120b"/>
                </ComboBox>
                <Button x:Name="ModelInfoHelpBtn" Click="ModelInfoHelpBtn_Click" Content="?" HorizontalAlignment="Left" Margin="248,198,0,0" VerticalAlignment="Top" Width="22" Height="25" FontWeight="Bold"/>

                <!-- Right Column: Hook & Keys -->
                <Label Content="Settings:" HorizontalAlignment="Left" Margin="300,10,0,0" VerticalAlignment="Top" Width="150"/>
                <CheckBox x:Name="AiSoundEnabled" Checked="AiSoundEnabled_CheckedChanged" Unchecked="AiSoundEnabled_CheckedChanged" Content="Notification sound" HorizontalAlignment="Left" Margin="300,33,0,0" VerticalAlignment="Top" Width="280"/>
                <CheckBox x:Name="AiPhoneticEnabled" Checked="AiPhoneticEnabled_CheckedChanged" Unchecked="AiPhoneticEnabled_CheckedChanged" Content="Phonetic spelling &amp; slang" HorizontalAlignment="Left" Margin="300,55,0,0" VerticalAlignment="Top" Width="280"/>

                <Label Content="Keyboard Shortcuts:" HorizontalAlignment="Left" Margin="300,85,0,0" VerticalAlignment="Top" Width="180"/>
                <Button x:Name="RecordAccentHotkeyBtn" Click="RecordAccentHotkeyBtn_Click" Content="Accent Shortcut: Ctrl+T" HorizontalAlignment="Left" Margin="300,108,0,0" VerticalAlignment="Top" Width="305" Height="25"/>
                <Button x:Name="RecordTranslateHotkeyBtn" Click="RecordTranslateHotkeyBtn_Click" Content="Translate Shortcut: Ctrl+U" HorizontalAlignment="Left" Margin="300,138,0,0" VerticalAlignment="Top" Width="305" Height="25"/>
                <Button x:Name="RecordCorrectHotkeyBtn" Click="RecordCorrectHotkeyBtn_Click" Content="Correct Shortcut: Ctrl+H" HorizontalAlignment="Left" Margin="300,168,0,0" VerticalAlignment="Top" Width="305" Height="25"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="300,200,0,0" VerticalAlignment="Top">
                    <Label Content="Temperature:" Width="82" Padding="0,0,0,0" VerticalContentAlignment="Center"/>
                    <Slider x:Name="AiTemperature" ValueChanged="AiTemperature_ValueChanged" Minimum="0" Maximum="1" TickFrequency="0.1" IsSnapToTickEnabled="True" Width="140" VerticalAlignment="Center"/>
                    <Label x:Name="AiTemperatureLabel" Content="0.6" Width="30" Padding="4,0,0,0" VerticalContentAlignment="Center"/>
                </StackPanel>

                <Button x:Name="ManageKeysBtn" Click="ManageKeysBtn_Click" Content="Manage API Keys" HorizontalAlignment="Left" Margin="300,238,0,0" VerticalAlignment="Top" Width="148" Height="26"/>
                <Button x:Name="ManageProfilesBtn" Click="ManageProfilesBtn_Click" Content="Accent Profiles" HorizontalAlignment="Left" Margin="457,238,0,0" VerticalAlignment="Top" Width="148" Height="26"/>
            </Grid>

            <!-- Bottom Left Tab Navigation Buttons (Shared across both grids) -->
            <Button x:Name="TabLogParserBtn" Content="LOG PARSER" Click="TabLogParserBtn_Click" HorizontalAlignment="Left" Margin="10,238,0,0" VerticalAlignment="Top" Width="135" Height="26"/>
            <Button x:Name="TabAiAssistantBtn" Content="AI ASSISTANT" Click="TabAiAssistantBtn_Click" HorizontalAlignment="Left" Margin="150,238,0,0" VerticalAlignment="Top" Width="135" Height="26"/>
        </Grid>
    </DockPanel>
</Controls:MetroWindow>
