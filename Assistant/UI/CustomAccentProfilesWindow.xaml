<Controls:MetroWindow x:Class="Assistant.UI.CustomAccentProfilesWindow"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Assistant.UI"
                      mc:Ignorable="d"
                      WindowStartupLocation="CenterOwner"
                      ResizeMode="NoResize"
                      BorderThickness="0"
                      GlowBrush="Black"
                      Title="Manage Custom Accent Profiles" Height="380" Width="580" ShowInTaskbar="True" IsMinButtonEnabled="False" IsMaxRestoreButtonEnabled="False" ShowIconOnTitleBar="False" TitleCharacterCasing="Normal" Icon="../Resources/AppIcon.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: List & Actions -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Content="Accent Profiles:" FontWeight="Bold" Padding="0,0,0,5"/>

                <ListBox x:Name="ProfilesList" Grid.Row="1" SelectionChanged="ProfilesList_SelectionChanged" DisplayMemberPath="TargetAccent" BorderThickness="1" BorderBrush="#CCCCCC" Margin="0,0,0,10"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="NewProfileBtn" Grid.Column="0" Content="New" Click="NewProfileBtn_Click" Height="26"/>
                    <Button x:Name="DeleteProfileBtn" Grid.Column="2" Content="Delete" Click="DeleteProfileBtn_Click" Height="26" Background="#E53935" Foreground="White" BorderThickness="0"/>
                </Grid>
            </Grid>

            <!-- Right Column: Details Form -->
            <Grid Grid.Column="2" x:Name="DetailsGrid" IsEnabled="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Content="Target Accent Name:" FontWeight="SemiBold" Padding="0,0,0,2"/>
                <TextBox x:Name="ProfileNameInput" Grid.Row="1" Controls:TextBoxHelper.Watermark="e.g. British Accent" Height="26" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <Label Grid.Row="2" Content="Custom Speech Directives / Vocabulary / Rules:" FontWeight="SemiBold" Padding="0,0,0,2"/>
                <TextBox x:Name="ProfileDirectivesInput" Grid.Row="3" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" Controls:TextBoxHelper.Watermark="e.g. Use words like 'mate' or 'bruv'. Drop ending 'g' on verbs. Banned words: 'capisce'."/>

                <Button x:Name="SaveProfileBtn" Grid.Row="4" Content="Save Profile Settings" Click="SaveProfileBtn_Click" Height="28" FontWeight="SemiBold"/>
            </Grid>
        </Grid>

        <!-- Bottom row: Close -->
        <Grid Grid.Row="1">
            <Button x:Name="CloseBtn" Content="Close" Click="CloseBtn_Click" HorizontalAlignment="Right" Width="85" Height="28"/>
        </Grid>
    </Grid>
</Controls:MetroWindow>
