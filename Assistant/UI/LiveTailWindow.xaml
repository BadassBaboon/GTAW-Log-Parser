<Controls:MetroWindow x:Name="LiveTail" x:Class="Assistant.UI.LiveTailWindow"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Assistant.UI"
                      mc:Ignorable="d"
                      WindowStartupLocation="CenterScreen"
                      ResizeMode="CanResize"
                      Closing="LiveTail_Closing"
                      BorderThickness="0"
                      GlowBrush="Black"
                      Title="Live Tail" Height="500" Width="700"
                      MinHeight="300" MinWidth="500"
                      IsMaxRestoreButtonEnabled="True" IsMinButtonEnabled="True"
                      TitleCharacterCasing="Normal" ShowIconOnTitleBar="False"
                      Icon="../Resources/AppIcon.ico">

    <DockPanel Margin="10">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label x:Name="StatusLabel" Grid.Column="0" Content="Idle" VerticalAlignment="Center" FontWeight="DemiBold"/>
            <CheckBox x:Name="RemoveTimestamps" Grid.Column="1" Content="Remove timestamps" VerticalAlignment="Center" Margin="0,0,15,0"
                      Checked="RemoveTimestamps_CheckedChanged" Unchecked="RemoveTimestamps_CheckedChanged"/>
            <Button x:Name="ToggleWatch" Grid.Column="2" Content="Start" Width="80" Click="ToggleWatch_Click"/>
        </Grid>

        <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="Counter" Grid.Column="0" Text="0 characters and 0 lines" VerticalAlignment="Center"/>
            <Button x:Name="ClearButton" Grid.Column="1" Content="Clear" Width="80" Click="ClearButton_Click"/>
        </Grid>

        <TextBox x:Name="Tail" AcceptsReturn="True" IsReadOnly="True"
                 VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled"
                 TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                 TextChanged="Tail_TextChanged"/>
    </DockPanel>
</Controls:MetroWindow>
